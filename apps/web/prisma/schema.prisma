generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Plan {
  id               String         @id @default(cuid())
  merchantPubkey   String
  name             String
  /// Amount in AUDD smallest units (stringified integer)
  amountAtomic     String
  interval         String         @default("month")
  /// Optional: basis points taken from payment to platform treasury (0–10000)
  feeBps           Int            @default(0)
  createdAt        DateTime       @default(now())
  subscriptions    Subscription[]
}

model Subscription {
  id               String   @id @default(cuid())
  planId           String
  plan             Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriberPubkey String
  status           String
  nextDue          DateTime?
  lastPaidTx       String?
  createdAt        DateTime @default(now())

  @@unique([planId, subscriberPubkey])
  @@index([planId])
  @@index([subscriberPubkey])
}
